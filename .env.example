# Copy to .env to override defaults, then `docker compose up`.

# LLM used for extraction, scoring, and chat.
# Default qwen3:8b needs ~5.5 GiB RAM available to the Ollama container.
# On low-memory machines, use a lighter model:
#   LLM_MODEL=qwen3:4b      # ~3.3 GiB
#   LLM_MODEL=deepseek-r1:8b
LLM_MODEL=qwen3:8b

# Embedding model (768-dim). Change EMBED_DIM in backend config if you swap this.
EMBED_MODEL=nomic-embed-text

# How long the API waits for one LLM call (seconds). CPU inference of 8B models
# is slow — raise this on weak hardware. Lower it after switching to qwen3:4b.
LLM_TIMEOUT=900
EMBED_TIMEOUT=300

# Max characters of resume/JD text sent to the LLM per call. Smaller = faster on CPU.
LLM_MAX_INPUT_CHARS=16000

# Parallel scoring LLM calls during matching. Lower to 1 on weak CPUs to avoid
# overloading Ollama (which causes timeouts).
SCORING_CONCURRENCY=3
